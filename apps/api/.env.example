# Verra API Environment Configuration Blueprint
# Copy this file to .env inside apps/api/ during setup

# Execution environment
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Database Configuration (Development: SQLite, Production: PostgreSQL)
# Local SQLite: sqlite:///verra.db
# Production PostgreSQL example: postgresql://username:password@localhost:5432/verra
DATABASE_URL=sqlite:///verra.db

# Authentication Security Signature Secret (Must override in production)
JWT_SECRET=verra-production-secret-key-32-character-long

# Autocomplete model weights file path configuration
MODEL_PATH=app/models/best_model.h5

# Default generation parameter fallbacks
DECODING_STRATEGY=top_k
TOP_K=8
TEMPERATURE=0.8
PROBABILITY_FLOOR=0.01

# Advanced stopping limits
CONFIDENCE_THRESHOLD=0.025
MAX_COMPLETION_WORDS=12
MIN_INPUT_WORDS=3
REPETITION_WINDOW=4
